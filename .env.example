# ============================================================
# Old Times RP Discord Bot – Environment Configuration
# ============================================================
# Kopírujte tento soubor jako .env a vyplňte hodnoty.

# ── Discord Bot ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
GUILD_ID=your_guild_id_here

# ── MySQL Databáze ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=discord_bot

# Automaticky přidělovaná role při vstupu na server
CLEN_ROLE_ID=333333333333333333

# ── Staff role IDs pro každou ticket kategorii ───────────────
# (více rolí oddělte čárkou, bez mezer)
ADMIN_STAFF_ROLES=444444444444444444,555555555555555555
DEV_STAFF_ROLES=666666666666666666
FACTION_STAFF_ROLES=777777777777777777,888888888888888888
VEDENI_STAFF_ROLES=111111111111111111,222222222222222222

# ── Discord Category Channel IDs ─────────────────────────────
# (kategorie, pod které budou vytvářeny ticket kanály)
TICKET_CATEGORY_ADMIN=900000000000000001
TICKET_CATEGORY_DEV=900000000000000002
TICKET_CATEGORY_FACTION=900000000000000003
TICKET_CATEGORY_VEDENI=900000000000000004
TICKET_CLOSED_CATEGORY=900000000000000005

# ── Log kanály ───────────────────────────────────────────────
TICKET_LOG_CHANNEL=900000000000000006
TRANSCRIPT_CHANNEL=900000000000000007
MOD_LOG_CHANNEL=900000000000000008
